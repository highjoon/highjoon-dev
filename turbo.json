{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "GITHUB_CLIENT_ID", "GITHUB_CLIENT_SECRET", "JWT_SECRET", "ADMIN_GITHUB_ID", "GITHUB_TOKEN", "NEXT_PUBLIC_GISCUS_REPO", "NEXT_PUBLIC_GISCUS_REPO_ID", "NEXT_PUBLIC_GISCUS_CATEGORY", "NEXT_PUBLIC_GISCUS_CATEGORY_ID"],
      "outputs": ["!.next/cache/**", ".next/**"]
    },
    "check-types": {
      "dependsOn": ["^type-check"]
    },
    "dev": {
      "cache": false
    },
    "lint:fix": {
      "dependsOn": [],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
